# Variables d'environnement — pro-repo
# Copier ce fichier en .env et remplir les valeurs

# Z.ai — API pour modèles LLM
# https://z.ai/manage-apikey/apikey-list
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai

# DeepSeek — API LLM (fallback)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI — API LLM (optionnel)
OPENAI_API_KEY=

# Make (Integromat) — Automatisation no-code
MAKE_API_KEY=

# Pipedrive — CRM
PIPEDRIE_API_KEY=

# Brevo — Email marketing
BREVO_API_KEY=

# GitHub — CI/CD
GITHUB_TOKEN=
